# Database (required)
# Get your connection string from Neon, Supabase, or your PostgreSQL provider
DATABASE_URL=postgresql://user:password@host:5432/database

# Better Auth Configuration (required)
BETTER_AUTH_URL=http://localhost:3000

# Email Configuration (required for password reset and email verification)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email sender address (must be verified in Resend)
# For development, use: Chrono <onboarding@resend.dev>
# For production, use your verified domain: Chrono <noreply@yourdomain.com>
EMAIL_FROM=Chrono <onboarding@resend.dev>

# Vercel Configuration (optional, only needed for Vercel deployments)
# VERCEL_URL=your-project.vercel.app
# VERCEL_PROJECT_PRODUCTION_URL=your-domain.com
